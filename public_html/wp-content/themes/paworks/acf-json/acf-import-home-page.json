                            {
                                "key": "field_home_hero_header",
                                "label": "Header",
                                "name": "header",
                                "type": "text"
                            },
                            {
                                "key": "field_home_hero_body",
                                "label": "Body Text",
                                "name": "body_text",
                                "type": "textarea",
                                "rows": 3,
                                "new_lines": "br"
