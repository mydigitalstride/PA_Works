                                "key": "field_home_hero_bg_image",
                                "label": "Background Image",
                                "name": "background_image",
                                "type": "image",
                                "return_format": "array",
                                "preview_size": "medium",
                                "instructions": "Recommended size: 1920x800px."
                            },
                            {
                                "key": "field_home_hero_subheader",
                                "label": "Sub Header",
                                "name": "sub_header",
                                "type": "text",
                                "instructions": "Small text above the main heading."
