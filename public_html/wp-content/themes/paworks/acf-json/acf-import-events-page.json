[
    {
        "key": "group_events_page",
        "title": "Events Page Builder",
        "fields": [
            {
                "key": "field_events_sections",
                "label": "Page Sections",
                "name": "events_sections",
                "type": "flexible_content",
                "button_label": "Add Section",
                "layouts": {
                    "layout_events_hero": {
                        "key": "layout_events_hero",
                        "name": "hero_section",
                        "label": "Hero Section",
                        "display": "block",
