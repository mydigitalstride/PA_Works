                                    {"key":"field_about_board_name","label":"Name","name":"name","type":"text"},
                                    {"key":"field_about_board_position","label":"Position / Title","name":"position","type":"text","instructions":"e.g., \"CEO\", \"Director\""},
                                    {"key":"field_about_board_org","label":"Organization","name":"organization","type":"text"},
