                                    {"key":"field_about_mission_box_color","label":"Box Style","name":"box_style","type":"select","choices":{"yellow":"Yellow / Gold","blue":"Blue / Teal","navy":"Navy","orange":"Orange"},"default_value":"yellow"}
                                ]
                            }
                        ]
                    },
                    "layout_about_team": {
                        "key": "layout_about_team",
